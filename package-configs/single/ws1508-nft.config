# 核心：目标设备、Docker、漏洞缓解
CONFIG_TARGET_meson=y
CONFIG_TARGET_meson_meson8b=y
CONFIG_TARGET_meson_meson8b_DEVICE_thunder-ws1508=y
CONFIG_KERNEL_BUILD_USER="LunaticKochiya"
