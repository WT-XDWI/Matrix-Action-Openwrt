CONFIG_TARGET_meson=y
CONFIG_TARGET_meson_meson8b=y

CONFIG_TARGET_meson_meson8b_DEVICE_thunder-ws1508=y

CONFIG_KERNEL_BUILD_USER="LunaticKochiya"
CONFIG_KERNEL_BUILD_DOMAIN="Github"
CONFIG_DOCKER=y
CONFIG_DOCKER=y

# 跳过导致编译失败的 xray-core（加固版）
# CONFIG_PACKAGE_xray-core is not set
CONFIG_PACKAGE_xray-core=n

# 添加 Turbo ACC 图形化管理界面
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_kmod-shortcut-fe=y
CONFIG_PACKAGE_kmod-fast-classifier=y

# 重新启用 lunatic7 软件源
CONFIG_FEED_lunatic7=y

# 缓解 Dirty Frag 漏洞 (CVE-2026-41169)
# CONFIG_PACKAGE_kmod-xfrm-esp is not set
# CONFIG_PACKAGE_kmod-af-rxrpc is not set

# 缓解 CopyFail 漏洞 (CVE-2026-31431)
# CONFIG_PACKAGE_kmod-algif-aead is not set

# 缓解 Seawrite 漏洞 (CVE-2026-21611)
CONFIG_IO_URING_DISABLED=y
